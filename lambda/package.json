{
  "name": "cookscan-ocr-lambda",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node22 --outfile=dist/handler.mjs --format=esm --external:@aws-sdk/*",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "package": "npm run build && cd dist && zip -r ../lambda.zip handler.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.19",
    "@aws-sdk/client-s3": "^3.1000.0",
    "ai": "^6.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^22.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.1"
  }
}
